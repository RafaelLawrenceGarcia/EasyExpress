  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ddabeb8ea613c6a4e9bfb0c5a3d2dbb9, type: 3}
  m_Name: dlg_CloseUpPC
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speakerName: CEO
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: Excellent work! The PC boots perfectly now. All faults have been confirmed
      and fixed!
    showOnRightSide: 1
  - speakerName: CEO
    portrait: {fileID: -2004239264, guid: f8402f94a4b63d44d90bf003f6ad06e0, type: 3}
    text: Before we send it back, let's close up the case. Turn off the PC, then
      put the side panel and screws back on.
    showOnRightSide: 1
  - speakerName: CEO
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: A professional repair shop always returns hardware looking as clean and
      tidy as when it came in!
    showOnRightSide: 1
