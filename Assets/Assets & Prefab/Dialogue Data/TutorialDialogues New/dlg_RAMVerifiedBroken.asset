  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ddabeb8ea613c6a4e9bfb0c5a3d2dbb9, type: 3}
  m_Name: dlg_RAMVerifiedBroken
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: "See that? It powered on for a few seconds then shut down — POST failed again. That confirms it."
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: "The old RAM stick is dead. Always verify like this so you're 100%% sure before telling the customer."
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: "Now remove the old RAM one more time and put the new RAM back in to finish the repair."
    showOnRightSide: 0