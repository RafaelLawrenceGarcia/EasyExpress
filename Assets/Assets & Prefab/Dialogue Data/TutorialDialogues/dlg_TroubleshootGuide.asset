MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ddabeb8ea613c6a4e9bfb0c5a3d2dbb9, type: 3}
  m_Name: dlg_TroubleshootGuide
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: Before I let you loose, here's a quick troubleshooting guide.
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: No display on monitor?
→ Check the GPU first, then the RAM.
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: PC won't turn on at all?
→ Check the PSU, motherboard, and CPU.
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: POST failure — fans spin then it shuts off?
→ Check the RAM and BIOS.
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: Overheating or random shutdowns?
→ Check the cooler, fans, and dust buildup.
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: Slow performance?
→ Check the storage drive and RAM.
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: Blue screen crashes?
→ Usually bad RAM or a failing storage drive.
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: Remember: swap one part at a time, test after each swap, and always verify.
    showOnRightSide: 0
