  m_Script: {fileID: 11500000, guid: ddabeb8ea613c6a4e9bfb0c5a3d2dbb9, type: 3}
  m_Name: OpeningSequence 2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speakerName: Oswold Johnson (Guide)
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: You're Doing Great Rookie, Now i want you Interact to a Customer
    showOnRightSide: 1
  - speakerName: Oswold Johnson (Guide)
    portrait: {fileID: -2004239264, guid: f8402f94a4b63d44d90bf003f6ad06e0, type: 3}
    text: By Pressing E you'll be able To talk to them and make Offer
    showOnRightSide: 1
  - speakerName: Oswold Johnson (Guide)
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: There's gonna be a Dialogue where the Customer would want Fix their Computer.
    showOnRightSide: 1
  - speakerName: Oswold Johnson (Guide)
    portrait: {fileID: -2004239264, guid: f8402f94a4b63d44d90bf003f6ad06e0, type: 3}
    text: So I want you to Accept 1 Offer by the Customer.
    showOnRightSide: 1
