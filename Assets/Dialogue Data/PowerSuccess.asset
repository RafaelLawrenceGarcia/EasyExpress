  m_Script: {fileID: 11500000, guid: ddabeb8ea613c6a4e9bfb0c5a3d2dbb9, type: 3}
  m_Name: PowerSuccess
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speakerName: Boss
    portrait: {fileID: 1984190853, guid: 1be9303cf68adf8469a107b28073a96a, type: 3}
    text: "Look at that \u2014 clean boot. Fans spinning, display working, no errors."
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: -2004239264, guid: f8402f94a4b63d44d90bf003f6ad06e0, type: 3}
    text: ' We''ve narrowed it down, the GPU and the RAM are both dead.'
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: -2004239264, guid: f8402f94a4b63d44d90bf003f6ad06e0, type: 3}
    text: Good news, you've already got replacement parts in your storage shelf.
      Let's go grab them.
    showOnRightSide: 0
  - speakerName: Boss
    portrait: {fileID: -2004239264, guid: f8402f94a4b63d44d90bf003f6ad06e0, type: 3}
    text: Exit the inspection, head to your storage, and pick up a new GPU and RAM
    showOnRightSide: 0
